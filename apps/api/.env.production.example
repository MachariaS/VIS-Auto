NODE_ENV=production
PORT=4000

# Database — Heroku provides DATABASE_URL automatically
DATABASE_URL=postgresql://user:pass@host:port/db

# Auth — use different secrets from staging
JWT_SECRET=replace-with-different-64-char-random-string
REFRESH_TOKEN_SECRET=replace-with-another-different-64-char-random-string

# CORS
FRONTEND_URL=https://vis-auto.vercel.app

# Email — Mailtrap for now, swap for real SMTP when ready
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your-mailtrap-user
SMTP_PASS=your-mailtrap-password
MAIL_FROM=VIS Auto <noreply@vis-auto.com>

# Schema
DB_SYNCHRONIZE=false

# Location
LOCATION_LOOKUP_MODE=free
