# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-64-char-random-hex-string
JWT_EXPIRES_IN=1d
REFRESH_TOKEN_SECRET=change-me-to-a-different-64-char-random-hex-string

# ── Database ──────────────────────────────────────────────────────────────────
# Heroku Postgres sets DATABASE_URL automatically — local dev uses the fields below
DATABASE_URL=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=vis_user
DB_PASSWORD=vis_password
DB_NAME=vis_assist
# NEVER set true in production
DB_SYNCHRONIZE=true

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
# Set to your Vercel URL in production (no trailing slash)
FRONTEND_URL=http://localhost:3000

# ── Google Maps ───────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=
LOCATION_LOOKUP_MODE=hybrid

# ── Email / OTP delivery ──────────────────────────────────────────────────────
# Leave all blank in dev — OTP codes are printed to the API console instead.
# Option A: Mailtrap API (production)
# MAILTRAP_TOKEN=your-mailtrap-api-token
# Option B: SMTP (Gmail, SendGrid, Mailgun, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
MAIL_FROM=VIS Auto <youraddress@gmail.com>
