NODE_ENV=production
PORT=4000

# Database — Railway provides DATABASE_URL automatically
DATABASE_URL=postgresql://user:pass@host:port/db

# Auth
JWT_SECRET=replace-with-64-char-random-string
REFRESH_TOKEN_SECRET=replace-with-different-64-char-random-string

# CORS
FRONTEND_URL=https://vis-auto-staging.vercel.app

# Email — use Mailtrap for staging (safe sandbox)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your-mailtrap-user
SMTP_PASS=your-mailtrap-password
MAIL_FROM=VIS Auto Staging <noreply@vis-auto.com>

# Schema — false in all deployed environments
DB_SYNCHRONIZE=false

# Location
LOCATION_LOOKUP_MODE=free
